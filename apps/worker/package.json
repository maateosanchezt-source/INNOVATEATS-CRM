{
  "name": "@innovateats/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src tests",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run --root . --config ../../vitest.config.ts",
    "test:unit": "vitest run tests/unit --root . --config ../../vitest.config.ts",
    "test:integration": "vitest run tests/integration --root . --config ../../vitest.config.ts --passWithNoTests"
  },
  "dependencies": {
    "@innovateats/agents": "workspace:*",
    "@innovateats/config": "workspace:*",
    "@innovateats/db": "workspace:*",
    "@innovateats/feature-flags": "workspace:*",
    "@innovateats/integrations": "workspace:*",
    "@innovateats/observability": "workspace:*",
    "@innovateats/shared": "workspace:*",
    "@innovateats/workflows": "workspace:*",
    "@temporalio/client": "1.20.3",
    "@temporalio/worker": "1.20.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
