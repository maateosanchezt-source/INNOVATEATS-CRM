{
  "name": "@innovateats/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bootstrap:runtime": "node dist/bootstrap-cli.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint src scripts tests drizzle.config.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run --root . --config ../../vitest.config.ts",
    "test:unit": "vitest run tests/unit --root . --config ../../vitest.config.ts --passWithNoTests",
    "test:integration": "vitest run tests/integration --root . --config ../../vitest.config.ts",
    "generate": "drizzle-kit generate",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:check": "tsx scripts/check-migrations.ts",
    "seed": "tsx scripts/seed.ts",
    "studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@innovateats/config": "workspace:*",
    "@innovateats/feature-flags": "workspace:*",
    "@innovateats/shared": "workspace:*",
    "drizzle-orm": "0.45.2",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.5.4",
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
